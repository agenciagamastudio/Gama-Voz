    "button": {
      "primary": {
        "background": "#88CE11",
        "color": "#000000",
        "padding": "12px 24px",
        "borderRadius": "12px",
        "fontWeight": "700",
        "transition": "300ms ease-in-out",
        "hover": {
          "filter": "brightness(1.1)"
        }
      },
      "secondary": {
        "background": "transparent",
        "border": "2px solid #88CE11",
        "color": "#88CE11",
        "padding": "12px 24px",
        "borderRadius": "12px"
      },
      "tertiary": {
        "background": "transparent",
        "color": "#A1A1AA",
        "padding": "12px 24px"
      }
    },
    "card": {
      "background": "#272727",
      "border": "1px solid rgba(255, 255, 255, 0.1)",
      "borderRadius": "16px",
      "padding": "32px",
      "boxShadow": "0 4px 12px rgba(0, 0, 0, 0.3)",
      "transition": "300ms ease-in-out"
    },
    "input": {
      "background": "#272727",
      "border": "1px solid rgba(255, 255, 255, 0.1)",
      "borderRadius": "8px",
      "padding": "12px 16px",
