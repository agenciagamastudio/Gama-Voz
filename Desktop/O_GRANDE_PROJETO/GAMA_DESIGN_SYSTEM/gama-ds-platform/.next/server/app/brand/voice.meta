{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/brand/layout,_N_T_/brand/voice/layout,_N_T_/brand/voice/page,_N_T_/brand/voice"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/brand/voice/__PAGE__",
    "/brand/voice",
    "/brand",
    "/_index",
    "/_head"
  ]
}