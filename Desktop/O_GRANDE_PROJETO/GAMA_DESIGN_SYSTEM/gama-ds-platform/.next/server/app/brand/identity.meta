{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/brand/layout,_N_T_/brand/identity/layout,_N_T_/brand/identity/page,_N_T_/brand/identity"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/brand/identity/__PAGE__",
    "/brand/identity",
    "/brand",
    "/_index",
    "/_head"
  ]
}