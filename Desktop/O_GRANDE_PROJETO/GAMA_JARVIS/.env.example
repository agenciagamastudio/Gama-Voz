# GAMA Jarvis Configuration
# Copie este arquivo para .env e preencha as configurações

# ============================================================================
# OLLAMA (100% Local e Gratuito - Sem API Key Necessária!)
# ============================================================================
# URL onde Ollama está rodando (padrão: localhost:11434)
OLLAMA_URL=http://localhost:11434

# Modelo Ollama a usar (recomendado: llama3.2 - leve e rápido)
# Antes de rodar, execute:
#   ollama pull llama3.2
OLLAMA_MODEL=llama3.2

# ============================================================================
# PORCUPINE WAKE WORD (Opcional)
# ============================================================================
# Se não tiver, Jarvis usa Google Speech Recognition como fallback
PORCUPINE_ACCESS_KEY=

# ============================================================================
# MONITOR API
# ============================================================================
# URL onde GAMA_MONITOR está rodando
MONITOR_API_URL=http://localhost:3015/api

# ============================================================================
# DEBUG MODE
# ============================================================================
DEBUG=false
