{
  "name": "gama-education-backend",
  "version": "1.0.0",
  "description": "GAMA Educação - Plataforma de Educação Personalizada com IA",
  "main": "dist/server.js",
  "type": "module",
  "bin": {
    "gama-education": "./bin/gama-education.cjs"
  },
  "scripts": {
    "setup": "node setup.cjs",
    "dev": "ts-node-dev --respawn src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "migrate": "ts-node src/db/migrate.ts up",
    "migrate:status": "ts-node src/db/migrate.ts status",
    "seed": "ts-node src/db/seed.ts",
    "db:setup": "npm run migrate && npm run seed",
    "dev:all": "concurrently --names \"Backend,Frontend\" --prefix-colors \"cyan,magenta\" --kill-others \"npm run dev\" \"cd frontend && npm run dev\""
  },
  "keywords": [
    "education",
    "personalized-learning",
    "ai",
    "gama"
  ],
  "author": "Orion",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@types/pdfkit": "^0.17.6",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^7.1.5",
    "jsonwebtoken": "^9.0.3",
    "neo4j-driver": "^5.14.0",
    "pdfkit": "^0.18.0",
    "pg": "^8.10.0",
    "uuid": "^9.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.19.37",
    "@types/pg": "^8.11.3",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.16.0",
    "@typescript-eslint/parser": "^6.16.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "directories": {
    "doc": "docs",
    "test": "tests"
  }
}
